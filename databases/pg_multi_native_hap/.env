# =============================================================================
# PostgreSQL 18 Multi-Master Cluster - Environment Configuration
# =============================================================================

# --- PostgreSQL ---
POSTGRES_VERSION=18
POSTGRES_DB=appdb
POSTGRES_USER=postgres
POSTGRES_PASSWORD=changeme_postgres_2025
POSTGRES_REPL_USER=replicator
POSTGRES_REPL_PASSWORD=changeme_repl_2025
POSTGRES_MAX_CONNECTIONS=200

# --- HAProxy ---
HAPROXY_STATS_USER=admin
HAPROXY_STATS_PASSWORD=changeme_haproxy_2025
HAPROXY_WRITE_PORT=5432
HAPROXY_READ_PORT=5433
HAPROXY_STATS_PORT=7000

# --- Valkey ---
VALKEY_VERSION=9
VALKEY_PASSWORD=changeme_valkey_2025
VALKEY_MAXMEMORY=128mb
VALKEY_PORT=6379
VALKEY_SENTINEL_PORT=26379

# --- Network ---
CLUSTER_SUBNET=172.29.0.0/16

# --- pgBackRest ---
# Each node is an independent initdb (different system-id) -> needs its own stanza.
# NOT prefixed with PGBACKREST_ to avoid pgbackrest interpreting them as options.
BACKUP_STANZA_NODE1=pg-mm-node1
BACKUP_STANZA_NODE2=pg-mm-node2
BACKUP_STANZA_NODE3=pg-mm-node3

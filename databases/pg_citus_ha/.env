# =============================================================================
# Citus 14.0 Distributed PostgreSQL 18 Cluster with HA
# =============================================================================

# --- PostgreSQL ---
POSTGRES_VERSION=18
POSTGRES_DB=appdb
POSTGRES_USER=postgres
POSTGRES_PASSWORD=changeme_postgres_2025
POSTGRES_REPL_USER=replicator
POSTGRES_REPL_PASSWORD=changeme_repl_2025
POSTGRES_MAX_CONNECTIONS=200

# --- Citus ---
CITUS_SHARD_COUNT=32

# --- Keepalived (coordinator HA) ---
# VIP floats between coordinator and coordinator-standby
KEEPALIVED_VIP=172.34.0.100
KEEPALIVED_VRID=53
COORDINATOR_IP=172.34.0.10
COORDINATOR_STANDBY_IP=172.34.0.11

# --- Valkey ---
VALKEY_VERSION=9
VALKEY_PASSWORD=changeme_valkey_2025
VALKEY_MAXMEMORY=128mb
VALKEY_PORT=6879
VALKEY_SENTINEL_PORT=26879

# --- Network ---
# Uses 172.34.x.x to avoid conflicts with:
#   pg/              (172.28), pg_multi_native_hap/           (172.29),
#   pg_multi_native_flyway/ (172.30), pg_multi_pglogical/ (172.31),
#   pg_multi_pglogical_ka/ (172.32), pg_multi_native_ka/ (172.33)
CLUSTER_SUBNET=172.34.0.0/16

# --- pgBackRest ---
# 3 stanzas: coordinator+standby share system-id, each worker has its own.
# NOTE: These vars are prefixed BACKUP_ (not PGBACKREST_) to avoid pgBackRest
# interpreting them as config options via env. pgBackRest auto-maps any env var
# starting with PGBACKREST_ to config options (e.g. PGBACKREST_STANZA_WORKER1
# becomes invalid option "stanza-worker1").
BACKUP_STANZA_COORDINATOR=pg-citus-coordinator
BACKUP_STANZA_WORKER1=pg-citus-worker1
BACKUP_STANZA_WORKER2=pg-citus-worker2

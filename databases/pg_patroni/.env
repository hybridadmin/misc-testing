# =============================================================================
# PostgreSQL 18 HA Cluster with Patroni + etcd + HAProxy + PgBouncer
# =============================================================================

# --- PostgreSQL ---
POSTGRES_VERSION=18
POSTGRES_DB=appdb
POSTGRES_USER=postgres
POSTGRES_PASSWORD=changeme_postgres_2025
POSTGRES_REPL_USER=replicator
POSTGRES_REPL_PASSWORD=changeme_repl_2025
POSTGRES_MAX_CONNECTIONS=100

# --- Patroni ---
PATRONI_SCOPE=pg-patroni
PATRONI_SUPERUSER_USERNAME=postgres
PATRONI_SUPERUSER_PASSWORD=changeme_postgres_2025
PATRONI_REPLICATION_USERNAME=replicator
PATRONI_REPLICATION_PASSWORD=changeme_repl_2025

# --- etcd ---
ETCD_VERSION=v3.5.17

# --- HAProxy ---
HAPROXY_PORT_RW=5050
HAPROXY_PORT_RO=5051
HAPROXY_STATS_PORT=7070

# --- PgBouncer ---
PGBOUNCER_PORT=6432
PGBOUNCER_MAX_CLIENT_CONN=400
PGBOUNCER_DEFAULT_POOL_SIZE=25
PGBOUNCER_POOL_MODE=transaction

# --- Valkey ---
VALKEY_VERSION=9
VALKEY_PASSWORD=changeme_valkey_2025
VALKEY_MAXMEMORY=128mb
VALKEY_PORT=6999
VALKEY_SENTINEL_PORT=26999

# --- Network ---
# Uses 172.35.x.x to avoid conflicts with:
#   pg/              (172.28), pg_multi/           (172.29),
#   pg_multi_flyway/ (172.30), pg_multi_pglogical/ (172.31),
#   pg_multi_pglogical_ka/ (172.32), pg_multi_native_ka/ (172.33),
#   pg_citus_ha/     (172.34)
CLUSTER_SUBNET=172.35.0.0/16

# --- Static IPs ---
ETCD1_IP=172.35.0.2
ETCD2_IP=172.35.0.3
ETCD3_IP=172.35.0.4
PATRONI1_IP=172.35.0.10
PATRONI2_IP=172.35.0.11
PATRONI3_IP=172.35.0.12
HAPROXY_IP=172.35.0.20
PGBOUNCER_IP=172.35.0.21
VALKEY_MASTER_IP=172.35.0.30
VALKEY_REPLICA1_IP=172.35.0.31
VALKEY_REPLICA2_IP=172.35.0.32
VALKEY_SENTINEL1_IP=172.35.0.33
VALKEY_SENTINEL2_IP=172.35.0.34
VALKEY_SENTINEL3_IP=172.35.0.35

# --- External Ports ---
# PG direct access (bypass HAProxy/PgBouncer — for debugging)
PG_NODE1_PORT=6041
PG_NODE2_PORT=6042
PG_NODE3_PORT=6043
# Patroni REST API
PATRONI1_API_PORT=8041
PATRONI2_API_PORT=8042
PATRONI3_API_PORT=8043

# =============================================================================
# PostgreSQL 18 Multi-Master Cluster with pglogical - Environment Configuration
# =============================================================================

# --- PostgreSQL ---
POSTGRES_VERSION=18
POSTGRES_DB=appdb
POSTGRES_USER=postgres
POSTGRES_PASSWORD=changeme_postgres_2025
POSTGRES_REPL_USER=replicator
POSTGRES_REPL_PASSWORD=changeme_repl_2025
POSTGRES_MAX_CONNECTIONS=200

# --- HAProxy ---
HAPROXY_STATS_USER=admin
HAPROXY_STATS_PASSWORD=changeme_haproxy_2025
HAPROXY_WRITE_PORT=5632
HAPROXY_READ_PORT=5633
HAPROXY_STATS_PORT=7200

# --- Valkey ---
VALKEY_VERSION=9
VALKEY_PASSWORD=changeme_valkey_2025
VALKEY_MAXMEMORY=128mb
VALKEY_PORT=6579
VALKEY_SENTINEL_PORT=26579

# --- Network ---
# Uses 172.31.x.x to avoid conflicts with pg/ (172.28), pg_multi_native_hap/ (172.29), pg_multi_native_flyway/ (172.30)
CLUSTER_SUBNET=172.31.0.0/16

# =============================================================================
# pg_autobase — PostgreSQL 18 HA (Autobase-style)
# Patroni + etcd + HAProxy + PgBouncer + pgBackRest + Valkey
# =============================================================================

# --- PostgreSQL ---
POSTGRES_VERSION=18
POSTGRES_DB=appdb
POSTGRES_USER=postgres
POSTGRES_PASSWORD=changeme_postgres_2025
POSTGRES_REPL_USER=replicator
POSTGRES_REPL_PASSWORD=changeme_repl_2025
POSTGRES_MAX_CONNECTIONS=200

# --- Patroni ---
PATRONI_SCOPE=pg-autobase
PATRONI_SUPERUSER_USERNAME=postgres
PATRONI_SUPERUSER_PASSWORD=changeme_postgres_2025
PATRONI_REPLICATION_USERNAME=replicator
PATRONI_REPLICATION_PASSWORD=changeme_repl_2025

# --- etcd ---
ETCD_VERSION=v3.5.17

# --- HAProxy (autobase-style 4-backend ports) ---
# NOTE: macOS AirPlay uses 5000, so we use 5050-5053 externally
# Internal container ports remain 5000-5003
HAPROXY_PORT_MASTER=5050
HAPROXY_PORT_REPLICAS=5051
HAPROXY_PORT_SYNC=5052
HAPROXY_PORT_ASYNC=5053
HAPROXY_STATS_PORT=7080

# --- PgBouncer ---
PGBOUNCER_PORT=6433
PGBOUNCER_MAX_CLIENT_CONN=1000
PGBOUNCER_DEFAULT_POOL_SIZE=50
PGBOUNCER_POOL_MODE=transaction

# --- pgBackRest ---
PGBACKREST_STANZA=pg-autobase
PGBACKREST_RETENTION_FULL=2
PGBACKREST_RETENTION_DIFF=3

# --- Valkey ---
VALKEY_VERSION=9
VALKEY_PASSWORD=changeme_valkey_2025
VALKEY_MAXMEMORY=128mb
VALKEY_PORT=7010
VALKEY_SENTINEL_PORT=27010

# --- Network ---
# Uses 172.36.x.x to avoid conflicts with:
#   pg_patroni_hap/    (172.28), pg_multi/           (172.29),
#   pg_multi_flyway/   (172.30), pg_multi_pglogical/ (172.31),
#   pg_multi_pglogical_ka/ (172.32), pg_multi_native_ka/ (172.33),
#   pg_citus_ha/       (172.34), pg_patroni/         (172.35)
CLUSTER_SUBNET=172.36.0.0/16

# --- Static IPs ---
ETCD1_IP=172.36.0.2
ETCD2_IP=172.36.0.3
ETCD3_IP=172.36.0.4
PATRONI1_IP=172.36.0.10
PATRONI2_IP=172.36.0.11
PATRONI3_IP=172.36.0.12
HAPROXY_IP=172.36.0.20
PGBOUNCER_IP=172.36.0.21
VALKEY_MASTER_IP=172.36.0.30
VALKEY_REPLICA1_IP=172.36.0.31
VALKEY_REPLICA2_IP=172.36.0.32
VALKEY_SENTINEL1_IP=172.36.0.33
VALKEY_SENTINEL2_IP=172.36.0.34
VALKEY_SENTINEL3_IP=172.36.0.35

# --- External Ports ---
# PG direct access (bypass HAProxy/PgBouncer — for debugging)
PG_NODE1_PORT=6051
PG_NODE2_PORT=6052
PG_NODE3_PORT=6053
# Patroni REST API
PATRONI1_API_PORT=8051
PATRONI2_API_PORT=8052
PATRONI3_API_PORT=8053

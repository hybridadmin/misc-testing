# =============================================================================
# pg_spock — PostgreSQL 18 + Spock Multi-Master Cluster
# 2x R/W (Spock bidirectional) + 2x RO (streaming replicas) + HAProxy
# =============================================================================

# --- PostgreSQL ---
POSTGRES_VERSION=18.3
POSTGRES_DB=spockdb
POSTGRES_USER=postgres
POSTGRES_PASSWORD=postgres
POSTGRES_REPL_USER=replicator
POSTGRES_REPL_PASSWORD=replicator
POSTGRES_MAX_CONNECTIONS=200

# --- Spock ---
SPOCK_VERSION=v5.0.6

# --- pgBackRest ---
PGBACKREST_STANZA=pg-spock

# --- HAProxy ---
# NOTE: macOS AirPlay uses 5000/7000, so we use 15000/15001/17000 externally
# Internal container ports remain 5000/5001/7000
HAPROXY_RW_PORT=15000
HAPROXY_RO_PORT=15001
HAPROXY_STATS_PORT=17000

# --- External Ports ---
# PG direct access (bypass HAProxy — for debugging and setup)
PG_NODE1_PORT=15432
PG_NODE2_PORT=15433
PG_NODE3_PORT=15434
PG_NODE4_PORT=15435

# --- Network ---
# Uses 172.37.x.x to avoid conflicts with other clusters:
#   pg_patroni_hap/    (172.28), pg_multi_native_hap/           (172.29),
#   pg_multi_native_flyway/   (172.30), pg_multi_pglogical/ (172.31),
#   pg_multi_pglogical_ka/ (172.32), pg_multi_native_ka/ (172.33),
#   pg_citus_ha/       (172.34), pg_patroni/         (172.35),
#   pg_autobase/       (172.36)
CLUSTER_SUBNET=172.37.0.0/16

# --- Static IPs ---
NODE1_IP=172.37.0.10
NODE2_IP=172.37.0.11
NODE3_IP=172.37.0.12
NODE4_IP=172.37.0.13
HAPROXY_IP=172.37.0.20

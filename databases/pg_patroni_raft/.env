# =============================================================================
# PostgreSQL HA Cluster - Environment Configuration
# Patroni + Raft (built-in DCS) + keepalived (VIP) + pgBackRest + Valkey
# =============================================================================
# No external DCS (etcd/consul/zookeeper) — Patroni uses built-in Raft
# consensus via pysyncobj. The 3 Patroni nodes form their own Raft group.
# =============================================================================

# --- PostgreSQL ---
POSTGRES_VERSION=18
POSTGRES_DB=appdb
POSTGRES_USER=postgres
POSTGRES_PASSWORD=changeme_postgres_2025
POSTGRES_REPL_USER=replicator
POSTGRES_REPL_PASSWORD=changeme_repl_2025
POSTGRES_MAX_CONNECTIONS=200

# --- Patroni ---
PATRONI_SCOPE=pg-patroni-raft
PATRONI_SUPERUSER_PASSWORD=changeme_postgres_2025
PATRONI_REPLICATION_PASSWORD=changeme_repl_2025
PATRONI_RESTAPI_USERNAME=patroni
PATRONI_RESTAPI_PASSWORD=changeme_patroni_2025

# --- Raft (built-in DCS) ---
RAFT_PORT=8009

# --- keepalived ---
KEEPALIVED_VIP=172.31.0.100
KEEPALIVED_VRID=54
PG_NODE1_IP=172.31.0.11
PG_NODE2_IP=172.31.0.12
PG_NODE3_IP=172.31.0.13

# --- Valkey ---
VALKEY_VERSION=9
VALKEY_PASSWORD=changeme_valkey_2025
VALKEY_MAXMEMORY=128mb
VALKEY_PORT=6379
VALKEY_SENTINEL_PORT=26379

# --- pgBackRest ---
BACKUP_STANZA=pg-patroni-raft

# --- Network ---
CLUSTER_SUBNET=172.31.0.0/16

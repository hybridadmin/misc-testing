# =============================================================================
# PostgreSQL 18 Multi-Master Cluster with pglogical + keepalived VIP
# =============================================================================

# --- PostgreSQL ---
POSTGRES_VERSION=18
POSTGRES_DB=appdb
POSTGRES_USER=postgres
POSTGRES_PASSWORD=changeme_postgres_2025
POSTGRES_REPL_USER=replicator
POSTGRES_REPL_PASSWORD=changeme_repl_2025
POSTGRES_MAX_CONNECTIONS=200

# --- Keepalived ---
# Virtual IP address on the Docker bridge subnet — only one node holds this at a time
KEEPALIVED_VIP=172.32.0.100
KEEPALIVED_VRID=51
# Static IPs for unicast VRRP (Docker doesn't support multicast)
PG_NODE1_IP=172.32.0.11
PG_NODE2_IP=172.32.0.12
PG_NODE3_IP=172.32.0.13

# --- Valkey ---
VALKEY_VERSION=9
VALKEY_PASSWORD=changeme_valkey_2025
VALKEY_MAXMEMORY=128mb
VALKEY_PORT=6679
VALKEY_SENTINEL_PORT=26679

# --- Network ---
# Uses 172.32.x.x to avoid conflicts with:
#   pg/           (172.28), pg_multi/     (172.29),
#   pg_multi_flyway/ (172.30), pg_multi_pglogical/ (172.31)
CLUSTER_SUBNET=172.32.0.0/16

# =============================================================================
# PostgreSQL 18 Multi-Master Cluster with Native Logical Replication + keepalived VIP
# =============================================================================

# --- PostgreSQL ---
POSTGRES_VERSION=18
POSTGRES_DB=appdb
POSTGRES_USER=postgres
POSTGRES_PASSWORD=changeme_postgres_2025
POSTGRES_REPL_USER=replicator
POSTGRES_REPL_PASSWORD=changeme_repl_2025
POSTGRES_MAX_CONNECTIONS=200

# --- Keepalived ---
# Virtual IP address on the Docker bridge subnet — only one node holds this at a time
KEEPALIVED_VIP=172.33.0.100
KEEPALIVED_VRID=52
# Static IPs for unicast VRRP (Docker doesn't support multicast)
PG_NODE1_IP=172.33.0.11
PG_NODE2_IP=172.33.0.12
PG_NODE3_IP=172.33.0.13

# --- Valkey ---
VALKEY_VERSION=9
VALKEY_PASSWORD=changeme_valkey_2025
VALKEY_MAXMEMORY=128mb
VALKEY_PORT=6779
VALKEY_SENTINEL_PORT=26779

# --- Network ---
# Uses 172.33.x.x to avoid conflicts with:
#   pg/              (172.28), pg_multi_native_hap/           (172.29),
#   pg_multi_native_flyway/ (172.30), pg_multi_pglogical/ (172.31),
#   pg_multi_pglogical_ka/ (172.32)
CLUSTER_SUBNET=172.33.0.0/16

# --- pgBackRest ---
# Each node is an independent initdb (different system-id) -> needs its own stanza.
# NOT prefixed with PGBACKREST_ to avoid pgbackrest interpreting them as options.
BACKUP_STANZA_NODE1=pg-mmn-node1
BACKUP_STANZA_NODE2=pg-mmn-node2
BACKUP_STANZA_NODE3=pg-mmn-node3

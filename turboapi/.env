# PostgreSQL Configuration
POSTGRES_USER=appuser
POSTGRES_PASSWORD=changeme_prod_2024
POSTGRES_DB=app_db

# Application Settings
LOG_LEVEL=INFO
DEBUG=false

# Database Pool Settings

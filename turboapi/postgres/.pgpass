# PostgreSQL Password File
# Format: hostname:port:database:username:password
# IMPORTANT: Set permissions with: chmod 600 ~/.pgpass

# Primary connections
postgres_provider:5432:app_db:appuser:changeme_prod_2024
postgres_provider:5432:app_db:replicator:repl_password_secure_2024

# Replication
postgres_provider:5432:replication:replicator:repl_password_secure_2024

# All databases, replicator user
postgres_provider:5432:*:replicator:repl_password_secure_2024

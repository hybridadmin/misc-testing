# =============================================================================
# Forgejo Docker Compose - Environment Configuration (EXAMPLE)
# =============================================================================
# Copy this file to .env and change ALL default values before deploying.
# NEVER commit .env to version control.
# =============================================================================

# -- General ------------------------------------------------------------------
COMPOSE_PROJECT_NAME=forgejo

# -- Forgejo ------------------------------------------------------------------
FORGEJO_IMAGE=codeberg.org/forgejo/forgejo:14-rootless
FORGEJO_HTTP_PORT=3000
FORGEJO_SSH_PORT=2222

USER_UID=1000
USER_GID=1000

FORGEJO_ROOT_URL=https://git.example.com
FORGEJO_DOMAIN=git.example.com
FORGEJO_SSH_DOMAIN=git.example.com

# Generate with: openssl rand -hex 32
FORGEJO_SECRET_KEY=
FORGEJO_INTERNAL_TOKEN=
FORGEJO_LFS_JWT_SECRET=

# -- PostgreSQL ---------------------------------------------------------------
POSTGRES_USER=forgejo
POSTGRES_PASSWORD=
POSTGRES_DB=forgejo

# -- Valkey (Redis-compatible cache) ------------------------------------------
VALKEY_PASSWORD=

# -- Backup -------------------------------------------------------------------
BACKUP_INTERVAL_SECONDS=86400
BACKUP_RETENTION_DAYS=30

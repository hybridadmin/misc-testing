// =============================================================================
// Jenkins Pipeline — CI/CD for a single repo, multi-environment deploy
//
// Parameters:
//   ENVIRONMENT  – target environment (dev | staging | production)
//   IMAGE_TAG    – Docker image tag to build & deploy (e.g. v1.2.3, sha-abc1234)
//
// Credentials (configure in Jenkins → Manage Credentials):
//   ghcr-credentials   – Username/Password for ghcr.io (GitHub username + PAT)
//   github-ssh-key      – SSH private key for pushing to the GitOps repo
//
// Required tools on the Jenkins agent:
//   docker, python3, pip, kustomize, git
// =============================================================================

pipeline {
    agent any

    parameters {
        choice(
            name: 'ENVIRONMENT',
            choices: ['dev', 'staging', 'production'],
            description: 'Target deployment environment'
        )
        string(
            name: 'IMAGE_TAG',
            defaultValue: '',
            description: 'Image tag to build and deploy (e.g. v1.2.3). Leave blank to auto-generate from short SHA.'
        )
    }

    environment {
        // ── Container Registry ──────────────────────────────────────────
        REGISTRY        = 'ghcr.io'
        IMAGE_NAME      = 'OWNER/pipeline'          // TODO: replace with your org/repo
        FULL_IMAGE      = "${REGISTRY}/${IMAGE_NAME}"

        // ── GitOps Repo ─────────────────────────────────────────────────
        GITOPS_REPO     = 'git@github.com:OWNER/pipeline-gitops.git' // TODO: replace
        GITOPS_BRANCH   = 'main'

        // ── Credentials IDs (must match Jenkins credential store) ───────
        GHCR_CREDS_ID   = 'ghcr-credentials'
        GITOPS_SSH_ID   = 'github-ssh-key'
    }

    options {
        timestamps()
        disableConcurrentBuilds()
        buildDiscarder(logRotator(numToKeepStr: '20'))
        timeout(time: 30, unit: 'MINUTES')
    }

    stages {
        // ────────────────────────────────────────────────────────────────
        // 0. Resolve the image tag
        // ────────────────────────────────────────────────────────────────
        stage('Resolve Tag') {
            steps {
                script {
                    env.DEPLOY_TAG = params.IMAGE_TAG?.trim() ?
                        params.IMAGE_TAG.trim() :
                        "sha-${env.GIT_COMMIT?.take(7) ?: 'latest'}"
                    echo "Resolved image tag: ${env.DEPLOY_TAG}"
                    echo "Target environment: ${params.ENVIRONMENT}"
                }
            }
        }

        // ────────────────────────────────────────────────────────────────
        // 1. Test
        // ────────────────────────────────────────────────────────────────
        stage('Test') {
            steps {
                sh '''
                    python3 -m venv .venv
                    . .venv/bin/activate
                    pip install --quiet -r app/requirements-dev.txt
                    pytest app/tests/ -v --tb=short
                '''
            }
        }

        // ────────────────────────────────────────────────────────────────
        // 2. Build & Push Docker Image to GHCR
        // ────────────────────────────────────────────────────────────────
        stage('Build & Push') {
            steps {
                withCredentials([
                    usernamePassword(
                        credentialsId: env.GHCR_CREDS_ID,
                        usernameVariable: 'GHCR_USER',
                        passwordVariable: 'GHCR_TOKEN'
                    )
                ]) {
                    sh '''
                        echo "${GHCR_TOKEN}" | docker login ${REGISTRY} -u "${GHCR_USER}" --password-stdin

                        docker build \
                            --label "org.opencontainers.image.source=${BUILD_URL}" \
                            --label "org.opencontainers.image.revision=${GIT_COMMIT}" \
                            -t "${FULL_IMAGE}:${DEPLOY_TAG}" \
                            .

                        docker push "${FULL_IMAGE}:${DEPLOY_TAG}"
                    '''
                }
            }
        }

        // ────────────────────────────────────────────────────────────────
        // 3. Production Approval Gate
        // ────────────────────────────────────────────────────────────────
        stage('Approval') {
            when {
                expression { params.ENVIRONMENT == 'production' }
            }
            steps {
                input message: "Deploy ${env.DEPLOY_TAG} to PRODUCTION?",
                      ok: 'Approve & Deploy',
                      submitter: 'admin,release-managers'
            }
        }

        // ────────────────────────────────────────────────────────────────
        // 4. Update GitOps Repo (Kustomize overlay)
        // ────────────────────────────────────────────────────────────────
        stage('Deploy') {
            steps {
                sshagent(credentials: [env.GITOPS_SSH_ID]) {
                    sh """
                        # Clone the GitOps repo into a temp directory
                        rm -rf gitops-repo
                        git clone --depth 1 --branch ${GITOPS_BRANCH} ${GITOPS_REPO} gitops-repo

                        cd gitops-repo/k8s/overlays/${params.ENVIRONMENT}

                        # Update the image tag via kustomize
                        kustomize edit set image ${FULL_IMAGE}:${DEPLOY_TAG}

                        cd \${OLDPWD}/gitops-repo

                        # Commit & push if anything changed
                        git config user.name  "jenkins-ci"
                        git config user.email "jenkins-ci@users.noreply.github.com"
                        git add k8s/
                        if git diff --staged --quiet; then
                            echo "No manifest changes — image tag already set."
                        else
                            git commit -m "deploy: ${params.ENVIRONMENT} → ${DEPLOY_TAG}"
                            git push origin ${GITOPS_BRANCH}
                        fi
                    """
                }
            }
        }
    }

    // ────────────────────────────────────────────────────────────────────
    // Post-build actions
    // ────────────────────────────────────────────────────────────────────
    post {
        success {
            echo "Successfully deployed ${env.DEPLOY_TAG} to ${params.ENVIRONMENT}"
        }
        failure {
            echo "Pipeline failed — check the logs above."
            // Uncomment to send Slack notifications:
            // slackSend channel: '#deployments',
            //     color: 'danger',
            //     message: "FAILED: ${env.JOB_NAME} #${env.BUILD_NUMBER} — ${params.ENVIRONMENT} (${env.DEPLOY_TAG})"
        }
        cleanup {
            sh 'rm -rf gitops-repo .venv'
            sh 'docker logout ${REGISTRY} || true'
        }
    }
}

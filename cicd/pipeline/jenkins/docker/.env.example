# =================================================================
# Jenkins Docker Environment Variables
# Copy this file to .env and fill in values
# =================================================================

# ── Jenkins Admin ────────────────────────────────────────────
JENKINS_ADMIN_ID=admin
JENKINS_ADMIN_PASSWORD=change-me

# ── Jenkins URL ──────────────────────────────────────────────
JENKINS_URL=http://localhost:8080/
JENKINS_ADMIN_EMAIL=jenkins-admin@example.com

# ── Jenkins Resources ────────────────────────────────────────
JENKINS_HTTP_PORT=8080
JENKINS_AGENT_PORT=50000
JENKINS_HEAP_MIN=512m
JENKINS_HEAP_MAX=1024m
JENKINS_CPU_LIMIT=2.0
JENKINS_MEM_LIMIT=2G

# ── DinD Resources ───────────────────────────────────────────
DIND_CPU_LIMIT=2.0
DIND_MEM_LIMIT=2G

# ── Secrets ──────────────────────────────────────────────────
# Directory containing secret files for JCasC.
# Place your GitHub deploy key at: ./secrets/GITHUB_SSH_PRIVATE_KEY
JENKINS_SECRETS_DIR=./secrets

# ── Timezone ─────────────────────────────────────────────────
TZ=UTC

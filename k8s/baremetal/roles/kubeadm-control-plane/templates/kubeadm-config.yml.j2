---
# =============================================================================
# kubeadm configuration for control plane init
# https://kubernetes.io/docs/reference/config-api/kubeadm-config.v1beta4/
# =============================================================================
apiVersion: kubeadm.k8s.io/v1beta4
kind: ClusterConfiguration
kubernetesVersion: "v{{ kube_version }}.0"
controlPlaneEndpoint: "{{ control_plane_endpoint }}:{{ control_plane_port }}"
networking:
  podSubnet: "{{ pod_network_cidr }}"
  serviceSubnet: "{{ service_cidr }}"
  dnsDomain: "cluster.local"
# Enable audit logging, RBAC, and Node authorisation
apiServer:
  extraArgs:
    - name: "audit-log-path"
      value: "/var/log/kubernetes/audit.log"
    - name: "audit-log-maxage"
      value: "30"
    - name: "audit-log-maxbackup"
      value: "10"
    - name: "audit-log-maxsize"
      value: "100"
    # Security: disable anonymous auth, enable RBAC + Node
    - name: "authorization-mode"
      value: "Node,RBAC"
    - name: "enable-admission-plugins"
      value: "NodeRestriction,PodSecurity"
    # Profiling off in production
    - name: "profiling"
      value: "false"
  extraVolumes:
    - name: audit-log
      hostPath: /var/log/kubernetes
      mountPath: /var/log/kubernetes
      pathType: DirectoryOrCreate
controllerManager:
  extraArgs:
    # Bind for metrics scraping
    - name: "bind-address"
      value: "0.0.0.0"
    # Terminate pods gracefully on node shutdown
    - name: "pod-eviction-timeout"
      value: "30s"
    - name: "profiling"
      value: "false"
scheduler:
  extraArgs:
    - name: "bind-address"
      value: "0.0.0.0"
    - name: "profiling"
      value: "false"
etcd:
  local:
    extraArgs:
      # Listen on all interfaces for metrics scraping
      - name: "listen-metrics-urls"
        value: "http://0.0.0.0:2381"
---
apiVersion: kubeadm.k8s.io/v1beta4
kind: InitConfiguration
nodeRegistration:
  criSocket: "unix:///run/containerd/containerd.sock"
  kubeletExtraArgs:
    - name: "protect-kernel-defaults"
      value: "true"

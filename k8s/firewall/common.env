#!/usr/bin/env bash
# =============================================================================
# common.env - Shared variables and functions for K8s firewall scripts
# =============================================================================
# Usage: source this file from other scripts
#   source "$(dirname "$0")/common.env"
#
# Required environment variables (pass these when invoking any script):
#   ALLOWED_SSH_SOURCES  - Comma-separated list of IPs/CIDRs allowed to SSH
#                          e.g. "10.0.0.5,192.168.1.0/24,203.0.113.50"
#   CONTROL_PLANE_IPS    - Comma-separated list of control plane node IPs
#                          e.g. "10.0.1.10,10.0.1.11,10.0.1.12"
#   WORKER_NODE_IPS      - Comma-separated list of worker node IPs
#                          e.g. "10.0.2.10,10.0.2.11,10.0.2.12"
#   POD_CIDR             - Pod network CIDR (default: 10.244.0.0/16)
#   SERVICE_CIDR         - Service network CIDR (default: 10.96.0.0/12)
#
# Optional:
#   DRY_RUN              - Set to "true" to print rules without applying
#   IPTABLES_CMD         - Override iptables binary (default: iptables)
# =============================================================================

set -euo pipefail

# ---- Defaults ---------------------------------------------------------------
POD_CIDR="${POD_CIDR:-10.244.0.0/16}"
SERVICE_CIDR="${SERVICE_CIDR:-10.96.0.0/12}"
DRY_RUN="${DRY_RUN:-false}"
IPTABLES_CMD="${IPTABLES_CMD:-iptables}"

# ---- K8s Port Definitions ---------------------------------------------------
# Control plane ports
K8S_API_PORT=6443
ETCD_CLIENT_PORT=2379
ETCD_PEER_PORT=2380
SCHEDULER_PORT=10259
CONTROLLER_MANAGER_PORT=10257
KUBELET_API_PORT=10250

# Worker node ports
NODEPORT_RANGE_START=30000
NODEPORT_RANGE_END=32767
KUBE_PROXY_METRICS_PORT=10256

# CNI ports (Flannel VXLAN / Calico / Weave)
VXLAN_PORT=8472
CALICO_BGP_PORT=179
CALICO_TYPHA_PORT=5473
WEAVE_TCP_PORT=6783
WEAVE_UDP_PORT=6784

# CoreDNS
COREDNS_PORT=9153

# SSH
SSH_PORT=22

# ---- Helper Functions -------------------------------------------------------

log_info() {
    echo "[INFO]  $(date '+%Y-%m-%d %H:%M:%S') - $*"
}

log_warn() {
    echo "[WARN]  $(date '+%Y-%m-%d %H:%M:%S') - $*" >&2
}

log_error() {
    echo "[ERROR] $(date '+%Y-%m-%d %H:%M:%S') - $*" >&2
}

# Execute or print an iptables command depending on DRY_RUN
run_ipt() {
    if [[ "$DRY_RUN" == "true" ]]; then
        echo "  [DRY-RUN] $IPTABLES_CMD $*"
    else
        $IPTABLES_CMD "$@"
    fi
}

# Split a comma-separated list into an array (sets global SPLIT_RESULT)
split_csv() {
    local input="$1"
    IFS=',' read -ra SPLIT_RESULT <<< "$input"
}

# Validate that required variables are set
require_var() {
    local var_name="$1"
    if [[ -z "${!var_name:-}" ]]; then
        log_error "Required variable '$var_name' is not set."
        echo "  Export it before running this script, e.g.:"
        echo "    export $var_name=\"value\""
        exit 1
    fi
}

# Check for root privileges
require_root() {
    if [[ "$DRY_RUN" == "true" ]]; then
        log_warn "DRY_RUN is enabled - skipping root check."
        return
    fi
    if [[ "$(id -u)" -ne 0 ]]; then
        log_error "This script must be run as root (or with sudo)."
        exit 1
    fi
}

# Backup current iptables rules
backup_iptables() {
    local backup_dir="/var/backups/iptables"
    local timestamp
    timestamp="$(date '+%Y%m%d_%H%M%S')"
    local backup_file="${backup_dir}/iptables-backup-${timestamp}.rules"

    if [[ "$DRY_RUN" == "true" ]]; then
        log_info "[DRY-RUN] Would backup iptables rules to $backup_file"
        return
    fi

    mkdir -p "$backup_dir"
    iptables-save > "$backup_file"
    log_info "Current iptables rules backed up to $backup_file"
}

# Flush all rules in a specific chain or all chains
flush_chain() {
    local chain="${1:-}"
    if [[ -n "$chain" ]]; then
        run_ipt -F "$chain"
    else
        run_ipt -F
    fi
}

# Print a section header
print_section() {
    echo ""
    echo "# ================================================================"
    echo "# $*"
    echo "# ================================================================"
}

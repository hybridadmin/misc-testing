# =============================================================================
# Nominatim + External PostgreSQL 16 — Environment Configuration
# Copy this file to .env and adjust values to your setup.
# =============================================================================

# ---------- PostgreSQL ----------
POSTGRES_USER=nominatim
POSTGRES_PASSWORD=nominatim_password
POSTGRES_PORT=5432

# PostgreSQL tuning (adjust to your available RAM)
# Defaults below are conservative and work on machines with 4-8 GB RAM.
# For production / large imports, scale up proportionally:
#   shared_buffers       ~25% of RAM
#   effective_cache_size ~50-75% of RAM
#   maintenance_work_mem as high as possible during import (e.g. 10GB)
POSTGRES_SHM_SIZE=512m
POSTGRES_SHARED_BUFFERS=256MB
POSTGRES_MAINTENANCE_WORK_MEM=256MB
POSTGRES_AUTOVACUUM_WORK_MEM=128MB
POSTGRES_WORK_MEM=32MB
POSTGRES_EFFECTIVE_CACHE_SIZE=1GB
POSTGRES_SYNCHRONOUS_COMMIT=off
POSTGRES_MAX_WAL_SIZE=1GB
POSTGRES_CHECKPOINT_TIMEOUT=10min
POSTGRES_CHECKPOINT_COMPLETION_TARGET=0.9
POSTGRES_MAX_CONNECTIONS=200

# ---------- Nominatim — data source ----------
# URL to an OSM PBF extract (see https://download.geofabrik.de)
PBF_URL=https://download.geofabrik.de/europe/monaco-latest.osm.pbf
REPLICATION_URL=https://download.geofabrik.de/europe/monaco-updates/

# ---------- Nominatim — import ----------
IMPORT_STYLE=full
IMPORT_WIKIPEDIA=false
IMPORT_US_POSTCODES=false
IMPORT_GB_POSTCODES=false
IMPORT_TIGER_ADDRESSES=false
REVERSE_ONLY=false
THREADS=4

# ---------- Nominatim — updates ----------
# Options: continuous / once / catch-up / none
UPDATE_MODE=none
REPLICATION_UPDATE_INTERVAL=86400
REPLICATION_RECHECK_INTERVAL=900
FREEZE=false

# ---------- Nominatim — runtime ----------
NOMINATIM_PORT=8080
NOMINATIM_SHM_SIZE=1g
GUNICORN_WORKERS=4
WARMUP_ON_STARTUP=false
